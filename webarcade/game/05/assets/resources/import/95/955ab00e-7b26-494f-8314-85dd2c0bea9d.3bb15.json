[1,0,0,[["cc.TextAsset",["_name","text"],1]],[[0,0,1,3]],[[0,"lilian","{\r\n  \"1\": {\r\n    \"id\": 1001,\r\n    \"headline\": \"第一章\",\r\n    \"bg_img\": \"bg_img_1001\",\r\n    \"title\": \"边界村萌新\",\r\n    \"describe\": \"穿戴布衣和木剑，杀鸡逐鹿乐翻天，传奇一别十余年，又见萌新来怀旧。\",\r\n    \"lvl\": \"1-9级\",\r\n    \"task\": [\r\n      1001,\r\n      1002,\r\n      1003,\r\n      1004,\r\n      1005,\r\n      1006,\r\n      1007,\r\n      1009,\r\n      1010\r\n    ]\r\n  },\r\n  \"2\": {\r\n    \"id\": 1002,\r\n    \"headline\": \"第二章\",\r\n    \"bg_img\": \"bg_img_1002\",\r\n    \"title\": \"骷髅洞挂机\",\r\n    \"describe\": \"兴高采烈闯古墓，忘带火把黑漆漆，浪费回城和随机，惨被好友骂垃圾。\",\r\n    \"lvl\": \"10-19级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"3\": {\r\n    \"id\": 1003,\r\n    \"headline\": \"第三章\",\r\n    \"bg_img\": \"bg_img_1003\",\r\n    \"title\": \"僵尸洞爆书\",\r\n    \"describe\": \"一把锄头进矿洞，见人挖矿就想爆，通宵蹲守尸王殿，狗书烈火不是梦。\",\r\n    \"lvl\": \"20-29级\",\r\n    \"task\": [\r\n      3001,\r\n      3002,\r\n      3003,\r\n      3004,\r\n      3005,\r\n      3006,\r\n      3007,\r\n      3009,\r\n      3010\r\n    ]\r\n  },\r\n  \"4\": {\r\n    \"id\": 1004,\r\n    \"headline\": \"第四章\",\r\n    \"bg_img\": \"bg_img_1004\",\r\n    \"title\": \"沃玛刷套装\",\r\n    \"describe\": \"帮主大喊抢记忆。沃玛大厅开混战，记忆套装就是牛，不服沙城见分晓。\",\r\n    \"lvl\": \"30-39级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"5\": {\r\n    \"id\": 1005,\r\n    \"headline\": \"第五章\",\r\n    \"bg_img\": \"bg_img_1005\",\r\n    \"title\": \"蜈蚣洞抢怪\",\r\n    \"describe\": \"我挥半月你引怪，法师统统靠边站，占坑刷怪先清人，这块地盘爷包场。\",\r\n    \"lvl\": \"40-49级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"6\": {\r\n    \"id\": 1006,\r\n    \"headline\": \"第六章\",\r\n    \"bg_img\": \"bg_img_1006\",\r\n    \"title\": \"石墓阵烧猪\",\r\n    \"describe\": \"清包背满红蓝药，战士沦为工具人，法爷以前我不对，今晚药水我买单。\",\r\n    \"lvl\": \"50-59级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"7\": {\r\n    \"id\": 1007,\r\n    \"headline\": \"第七章\",\r\n    \"bg_img\": \"bg_img_1007\",\r\n    \"title\": \"神秘祖玛寺\",\r\n    \"describe\": \"祖玛装备属性好，极品卫士教做人，英雄迷失祖玛阁，道士隐身刷教主\",\r\n    \"lvl\": \"60-69级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"8\": {\r\n    \"id\": 1008,\r\n    \"headline\": \"第八章\",\r\n    \"bg_img\": \"bg_img_1008\",\r\n    \"title\": \"赤月之谜\",\r\n    \"describe\": \"描述8\",\r\n    \"lvl\": \"70-79级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"9\": {\r\n    \"id\": 1009,\r\n    \"headline\": \"第九章\",\r\n    \"bg_img\": \"bg_img_1009\",\r\n    \"title\": \"封魔殿\",\r\n    \"describe\": \"描述9\",\r\n    \"lvl\": \"80-89级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  },\r\n  \"10\": {\r\n    \"id\": 1010,\r\n    \"headline\": \"第十章\",\r\n    \"bg_img\": \"bg_img_1010\",\r\n    \"title\": \"魔龙宝藏\",\r\n    \"describe\": \"描述10\",\r\n    \"lvl\": \"90-99级\",\r\n    \"task\": [\r\n      2001,\r\n      2002,\r\n      2003,\r\n      2004,\r\n      2005,\r\n      2006,\r\n      2007,\r\n      2008,\r\n      2009,\r\n      2010\r\n    ]\r\n  }\r\n}"]],0,0,[],[],[]]