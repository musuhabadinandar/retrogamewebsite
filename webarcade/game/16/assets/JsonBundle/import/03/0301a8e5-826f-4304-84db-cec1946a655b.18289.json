[1,0,0,[["cc.JsonAsset",["_name","json"],1]],[[0,0,1,3]],[[0,"guide_talk",[{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":1,"whoTalk":1,"text":"师傅现传你修仙基本功法：盘膝而坐，吐纳千息，气凝丹田！","talkId":0,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":2,"whoTalk":2,"text":"这、这样吗？","talkId":0,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":3,"whoTalk":1,"text":"如此保持甚好，通全身脉络感知万物，则仙可修成！","talkId":0,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":4,"whoTalk":1,"text":"徒儿，已修行多时，可否感知体内异样？","talkId":1,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":5,"whoTalk":2,"text":"禀师傅，弟子体内灵气充沛，很难再吸收灵气","talkId":1,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":6,"whoTalk":1,"text":"赐你一道契机，助你突破","talkId":1,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":7,"whoTalk":2,"text":"我仿佛能听到周围草木的声音。","talkId":1100,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":8,"whoTalk":1,"text":"所言道法自然，随着你阶段提升，能感知万物天象的思想！","talkId":1100,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":9,"whoTalk":2,"text":"好的师傅，弟子继续努力。","talkId":1100,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":10,"whoTalk":1,"text":"很好，你的修为已经能启动仙晶灵匣了！","talkId":10,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":11,"whoTalk":2,"text":"这是？","talkId":10,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":12,"whoTalk":1,"text":"仙晶灵匣乃玄天门秘宝，蕴藏天才地宝，届是修仙珍贵资源","talkId":10,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":13,"whoTalk":1,"text":"灵匣可与玄天弟子共鸣，当弟子达到一定境界便可开启获得奖励","talkId":10,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":14,"whoTalk":2,"text":"练了这本秘笈，感觉吐纳更顺畅了","talkId":20,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":15,"whoTalk":1,"text":"甚好、甚好！功法秘笈乃世间珍宝，日后也注意多多收集。","talkId":20,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":16,"whoTalk":2,"text":"师父，我感觉最近修炼又停滞不少，有没有更快点的方法","talkId":30,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":17,"whoTalk":1,"text":"修仙者切忌浮躁！","talkId":30,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":18,"whoTalk":2,"text":"是，师父，我知道了","talkId":30,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":19,"whoTalk":1,"text":"唉，这里有几枚丹药，可帮助你纳灵吐气","talkId":30,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":20,"whoTalk":2,"text":"谢谢师父！","talkId":30,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":21,"whoTalk":2,"text":"师父，发生何事？怎么愁眉苦脸的","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":22,"whoTalk":1,"text":"最近山中内妖兽肆虐，百姓苦不堪言","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":23,"whoTalk":2,"text":"师父你一出手不就全解决了","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":24,"whoTalk":1,"text":"为师身上背负大因果，不能随便出手","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":25,"whoTalk":2,"text":"那让师兄们去？","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":26,"whoTalk":1,"text":"孙悟空，我观你之气息已到凡人巅峰","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":27,"whoTalk":2,"text":"嗯嗯，多亏了师父的教导，我才进步这么快","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":28,"whoTalk":1,"text":"既然如此，那就由你代替为师去一趟吧","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":29,"whoTalk":2,"text":"啊？去哪","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":30,"whoTalk":1,"text":"自然是云落山，妖兽多肆虐一日，周围百姓便多一日罪受。怎么，你不愿意？","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":31,"whoTalk":2,"text":"弟子自然愿意。修仙者自当除魔卫道，我这就前往云落山。","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":32,"whoTalk":1,"text":"嗯，此去多加小心，妖兽之中也不乏诡计多端者。","talkId":40,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":33,"whoTalk":2,"text":"云落山内竟然隐藏了这么多妖兽","talkId":50,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":34,"whoTalk":2,"text":"越是深入，妖兽的实力也越发强大，以我目前的实力，差不多到极限了","talkId":50,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":35,"whoTalk":2,"text":"来云落山前，师父曾说这个锦囊只有在实力不足时才能打开，现在应该是时候了","talkId":50,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":36,"whoTalk":2,"text":"这是、狮鹫内丹？","talkId":60,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":37,"whoTalk":1,"text":"高阶魔兽内丹可庇护修炼者稳渡雷劫突破境界登峰造极。","talkId":60,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":1,"id":38,"whoTalk":1,"text":"跟着为师指示，屏气凝神，抱元守一！","talkId":1000,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":39,"whoTalk":2,"text":"这就是新的境界吗！果然不一般，我感觉比刚才的我强了十倍。","talkId":1001,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":40,"whoTalk":1,"text":"你年纪轻轻已小成，为师果然未看走眼。","talkId":1001,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":41,"whoTalk":1,"text":"求道共分为二十个境界，无数修仙者穷其一生都无法突破，为师已在化神阶段停滞三百余年，传闻受到先祖玄天道真的点化者可真正修道成仙，或许为师命数中无此缘分…","talkId":1001,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"rightName":"孙悟空","rightAvatar":"dialog_avatar_luoli","leftName":"唐僧","touch":0,"id":42,"whoTalk":1,"text":"说的远了！徒儿谨记，万般修炼皆需根基扎实，方可挑战更高境界！","talkId":1001,"leftAvatar":"dialog_avatar_lingxiaozhenren"},{"r